#!/usr/bin/env bash
# Launch Claude Code with the kitty<-tmux shim active, scoped to THIS process
# only (does not shadow real tmux for the rest of your shell).
#
# Usage:  claude-kitty [any claude args...]

set -euo pipefail

SHIM_DIR="$HOME/.claude/kitty-tmux-shim"

# 1) Put only our fake tmux first on PATH.
export PATH="$SHIM_DIR/bin:$PATH"

# 2) Agent teams are experimental and off by default.
export CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# 3) Some auto-detection paths look at $TMUX to decide "am I inside tmux?".
#    Fake a session marker. If CC misbehaves (e.g. tries to capture the lead
#    pane oddly), comment this line out and rely on --teammate-mode tmux alone.
export TMUX="${TMUX:-/tmp/fake-tmux-shim,$$,0}"
export TMUX_PANE="${TMUX_PANE:-%0}"

# Sanity check: are we inside a kitty window with remote control reachable?
if [ -z "${KITTY_WINDOW_ID:-}" ]; then
  echo "warning: KITTY_WINDOW_ID is empty -- are you running inside kitty?" >&2
fi

exec claude --teammate-mode tmux "$@"
